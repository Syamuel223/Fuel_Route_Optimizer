  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://127.0.0.1:8000/api/health/",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8000",
          "path": ["api", "health", ""]
        },
        "description": "Check if the API is running"
      },
      "response": []
    },
    {
      "name": "Route NYC to Chicago",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://127.0.0.1:8000/api/route/?start=New%20York,%20NY&finish=Chicago,%20IL",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8000",
          "path": ["api", "route", ""],
          "query": [
            {
              "key": "start",
              "value": "New York, NY",
              "description": "Starting location (city, state)"
            },
            {
              "key": "finish",
              "value": "Chicago, IL",
              "description": "Destination location (city, state)"
            },
            {
              "key": "max_range_miles",
              "value": "500",
              "description": "Max vehicle range in miles (optional, default 500)"
            },
            {
              "key": "fuel_efficiency_mpg",
              "value": "10",
              "description": "Vehicle fuel efficiency in MPG (optional, default 10)"
            }
          ]
        },
        "description": "Plan route with optimal fuel stops from NYC to Chicago"
      },
      "response": []
    },
